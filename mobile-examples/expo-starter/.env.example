# MediChain Expo Mobile App Environment Configuration
# Copy this file to .env and customize for your environment
#
# IMPORTANT FOR MOBILE DEVELOPMENT:
# - 'localhost' does NOT work on mobile devices
# - Use your computer's local network IP (e.g., 192.168.x.x)
# - Find your IP: Windows: ipconfig | Mac/Linux: ifconfig
# - Both your computer and phone must be on the same network

# ============================================================================
# API Configuration (REQUIRED for mobile)
# ============================================================================

# API Base URL - MUST use your computer's network IP for mobile
# Find your IP:
#   Windows: Run 'ipconfig' in terminal, look for IPv4 Address
#   Mac/Linux: Run 'ifconfig' or 'ip addr', look for inet address
#
# Examples:
#   EXPO_PUBLIC_API_URL=http://192.168.1.100:8080
#   EXPO_PUBLIC_API_URL=http://10.0.0.50:8080
#   Production: https://api.medichain.example.com
EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:8080

# API request timeout in milliseconds (default: 30000)
EXPO_PUBLIC_API_TIMEOUT=30000

# ============================================================================
# Blockchain Configuration
# ============================================================================

# Substrate node WebSocket URL (uses same IP as API)
# Examples:
#   EXPO_PUBLIC_SUBSTRATE_WS_URL=ws://192.168.1.100:9944
#   Production: wss://chain.medichain.example.com
EXPO_PUBLIC_SUBSTRATE_WS_URL=ws://YOUR_COMPUTER_IP:9944

# ============================================================================
# Development Settings
# ============================================================================

# Enable debug mode for verbose logging
EXPO_PUBLIC_DEBUG=true

# Demo mode - uses mock data instead of real API
EXPO_PUBLIC_DEMO_MODE=false

# ============================================================================
# Feature Flags
# ============================================================================

# Enable biometric authentication (fingerprint/face)
EXPO_PUBLIC_FEATURE_BIOMETRIC=true

# Enable QR code scanning for patient identification
EXPO_PUBLIC_FEATURE_QR_SCAN=true

# Enable NFC for patient card reading
EXPO_PUBLIC_FEATURE_NFC=false

# Enable push notifications
EXPO_PUBLIC_FEATURE_PUSH_NOTIFICATIONS=false

# ============================================================================
# Android-Specific Settings
# ============================================================================

# Android Emulator Note:
# Use 10.0.2.2 instead of localhost to access host machine
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
# EXPO_PUBLIC_SUBSTRATE_WS_URL=ws://10.0.2.2:9944

# ============================================================================
# iOS-Specific Settings
# ============================================================================

# iOS Simulator Note:
# localhost works in iOS Simulator but not on physical devices
# For physical devices, use your computer's network IP

# ============================================================================
# Third-party Services (optional)
# ============================================================================

# Sentry DSN for error tracking
# EXPO_PUBLIC_SENTRY_DSN=

# Analytics tracking ID
# EXPO_PUBLIC_ANALYTICS_ID=
