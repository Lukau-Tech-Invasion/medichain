<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>CFBundleDevelopmentRegion</key>
        <string>$(DEVELOPMENT_LANGUAGE)</string>

        <key>CFBundleDisplayName</key>
        <string>MediChain</string>

        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>

        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>

        <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>

        <key>CFBundlePackageType</key>
        <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>

        <key>CFBundleShortVersionString</key>
        <string>1.0.0</string>

        <key>CFBundleVersion</key>
        <string>1</string>

        <key>LSRequiresIPhoneOS</key>
        <true/>

        <!-- URL Schemes for deep linking -->
        <key>CFBundleURLTypes</key>
        <array>
            <dict>
                <key>CFBundleURLSchemes</key>
                <array>
                    <string>medichain</string>
                </array>
                <key>CFBundleURLName</key>
                <string>app.medichain</string>
            </dict>
        </array>

        <!-- App Transport Security - DEVELOPMENT ONLY -->
        <!-- ⚠️ Remove for production! Production should only use HTTPS. -->
        <key>NSAppTransportSecurity</key>
        <dict>
            <!-- Allow arbitrary loads for development -->
            <key>NSAllowsArbitraryLoads</key>
            <true/>

            <!-- Exception domains for development -->
            <key>NSExceptionDomains</key>
            <dict>
                <key>localhost</key>
                <dict>
                    <key>NSExceptionAllowsInsecureHTTPLoads</key>
                    <true/>
                </dict>
                <!-- Add your development machine IP here -->
                <!-- Example:
			<key>192.168.1.100</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			-->
            </dict>
        </dict>

        <!-- Camera permission for QR code scanning -->
        <key>NSCameraUsageDescription</key>
        <string>MediChain needs camera access to scan patient QR codes for emergency access.</string>

        <!-- Face ID permission for biometric authentication -->
        <key>NSFaceIDUsageDescription</key>
        <string>MediChain uses Face ID to securely authenticate access to sensitive medical records.</string>

        <!-- NFC permission for card tap -->
        <key>NFCReaderUsageDescription</key>
        <string>MediChain uses NFC to read patient health ID cards for quick emergency access.</string>

        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>

        <key>UIRequiredDeviceCapabilities</key>
        <array>
            <string>armv7</string>
        </array>

        <key>UISupportedInterfaceOrientations</key>
        <array>
            <string>UIInterfaceOrientationPortrait</string>
            <string>UIInterfaceOrientationLandscapeLeft</string>
            <string>UIInterfaceOrientationLandscapeRight</string>
        </array>

        <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
            <string>UIInterfaceOrientationPortrait</string>
            <string>UIInterfaceOrientationPortraitUpsideDown</string>
            <string>UIInterfaceOrientationLandscapeLeft</string>
            <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
    </dict>
</plist>
