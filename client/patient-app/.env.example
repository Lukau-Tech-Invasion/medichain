# MediChain Patient App Environment Configuration
# Copy this file to .env.local and customize for your environment
# All VITE_ prefixed variables are exposed to the client

# ============================================================================
# API Configuration
# ============================================================================

# API Base URL (leave empty in development to use Vite proxy)
# For production, set to your API server URL
# Examples:
#   Development: (leave empty or comment out)
#   Local with IP: http://192.168.1.100:8080
#   Production: https://api.medichain.example.com
VITE_API_URL=

# API request timeout in milliseconds (default: 30000)
VITE_API_TIMEOUT=30000

# ============================================================================
# Blockchain Configuration
# ============================================================================

# Substrate node WebSocket URL
# Leave empty in development to use default (ws://127.0.0.1:9944)
# For production, set to your node URL
# Examples:
#   Local: ws://127.0.0.1:9944
#   Local with IP: ws://192.168.1.100:9944
#   Production: wss://chain.medichain.example.com
VITE_SUBSTRATE_WS_URL=

# ============================================================================
# Development Settings
# ============================================================================

# Enable debug logging (true/false)
VITE_DEBUG=false

# ============================================================================
# Feature Flags
# ============================================================================

# Enable appointment booking
VITE_FEATURE_APPOINTMENTS=true

# Enable prescription view/refill requests
VITE_FEATURE_PRESCRIPTIONS=true

# Enable document upload
VITE_FEATURE_DOCUMENT_UPLOAD=true

# Enable biometric authentication (fingerprint/face)
VITE_FEATURE_BIOMETRIC_AUTH=false

# ============================================================================
# Third-party Services (optional)
# ============================================================================

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# Analytics tracking ID
# VITE_ANALYTICS_ID=
