# ==============================================================================
# MediChain Environment Configuration
# Copy this file to .env and customize for your environment
# ==============================================================================

# Database Configuration
DATABASE_URL=postgresql://medichain:medichain_dev_2024@localhost:5432/medichain

# For Docker internal networking (when API runs in container)
DATABASE_URL_DOCKER=postgresql://medichain:medichain_dev_2024@postgres:5432/medichain

# ------------------------------------------------------------------------------
# docker-compose credentials (interpolated by docker-compose.yml)
# The compose file ships DEV-ONLY defaults; override ALL of these in production.
# ------------------------------------------------------------------------------
POSTGRES_USER=medichain
POSTGRES_PASSWORD=medichain_dev_2024
POSTGRES_DB=medichain
PGADMIN_DEFAULT_EMAIL=admin@medichain.local
PGADMIN_DEFAULT_PASSWORD=admin

# Application Configuration
RUST_LOG=info,sqlx=warn,medichain_api=debug
MEDICHAIN_DEV_MODE=true

# Connection Pool Settings
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=3
DB_IDLE_TIMEOUT_SECS=600
DB_MAX_LIFETIME_SECS=1800

# Connection Retry (for Docker startup timing)
DB_MAX_RETRIES=5

# Security (CHANGE IN PRODUCTION!)
# When IS_DEMO=false, the API refuses to start if these still hold demo values.
JWT_SECRET=medichain-demo-secret-key-change-in-production-2024
SESSION_SECRET=medichain-dev-secret-change-in-production
SESSION_DURATION_HOURS=24

# SECURE BY DEFAULT: the API enables wallet signature verification unless you
# opt out. IS_DEMO=true disables signature verification (so X-User-Id alone is
# accepted) AND relaxes the startup secret-validation gate — for LOCAL/DEMO ONLY.
# Set IS_DEMO=false for production (the default when this var is unset).
# Override precedence: REQUIRE_SIGNATURES=true|false overrides the IS_DEMO default.
IS_DEMO=true

# Blockchain Node (Substrate)
SUBSTRATE_WS_URL=ws://127.0.0.1:9944

# IPFS Configuration
IPFS_URL=http://127.0.0.1:5001

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8080

# ------------------------------------------------------------------------------
# Telehealth Video (Phase 5.1)
# Provider: jitsi (default) | internal | daily | twilio
#   jitsi    — real WebRTC video via a Jitsi Meet server; NO API key required.
#              Rooms are created on join, so the URLs open a working call.
#   internal — self-hosted HMAC token URLs (needs your own room page).
#   daily    — Daily.co       (requires DAILY_API_KEY)
#   twilio   — Twilio Video   (requires TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN)
# ------------------------------------------------------------------------------
TELEHEALTH_PROVIDER=jitsi
# Public instance by default; point at a SELF-HOSTED Jitsi for production / PHI.
JITSI_DOMAIN=meet.jit.si
JITSI_ROOM_PREFIX=MediChain
# Jitsi JWT auth (Phase 1) — ONLY works with a self-hosted Jitsi configured for
# Prosody token auth (or 8x8 JaaS). On public meet.jit.si these are ignored.
# Set JITSI_APP_SECRET to the Prosody `app_secret`; leaving it unset = open rooms.
# JITSI_APP_ID=medichain
# JITSI_APP_SECRET=change-me-to-your-prosody-app-secret
# Credentials for the SaaS providers (only needed if you select them):
# DAILY_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# InternalProvider tuning (only used when TELEHEALTH_PROVIDER=internal):
# TELEHEALTH_SECRET=medichain-telehealth-dev-secret
# MEDICHAIN_DOMAIN=app.medichain.health
# In-app web base for single-tap mobile join (QR / 302 redirect, Phase 4).
# The QR/redirect targets <MEDICHAIN_APP_URL>/telehealth?session=...&join=1 so
# phones open the consultation INSIDE the MediChain PWA — no native-app download.
# MEDICHAIN_APP_URL=https://app.medichain.health
# Recording transcription (Phase 6). "none" (default) = no transcription and no
# external key needed. Real STT (google/aws/azure) requires its own SDK + creds
# and E2EE disabled + consent — see docs/e2ee-policy.md.
# TRANSCRIPTION_PROVIDER=none

# ------------------------------------------------------------------------------
# Incident response (Phase 11.4)
# ------------------------------------------------------------------------------
# Comma-separated phone number(s) (E.164) that receive an SMS when a breach is
# declared via POST /api/admin/security/breach. Requires Africa's Talking SMS
# config (AT_USERNAME + AT_API_KEY) to actually send; otherwise logged only.
# SECURITY_OFFICER_PHONE=+27123456789
